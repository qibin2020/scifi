# Backup / archive / misc
.misc/
**/*.bak
**/*.bak.*
**/*.bak/
**/*.bak.*/

# Archives & compressed
**/*.tar
**/*.tar.gz
**/*.tgz
**/*.gz
**/*.zip
**/*.7z
**/*.bz2
**/*.xz

# Containers & overlays
**/*.sif
**/*.img

# Python
**/__pycache__/
**/*.pyc
**/*.pyo

# Logs & job output
**/*.log
**/*.out
**/*.err

# F runtime artifacts
F/tasks/
F/run/
F/mnt/*
!F/mnt/.gitkeep
!F/mnt/sci_shared/
F/home/*

# Move-aside cleanups (rename-with-suffix instead of delete)
**/*.deleted
**/*.deleted-*
**/.deleted-*

# bench tooling runtime artifacts (tools/bench/bench.py creates these)
tools/bench/runs/
tools/bench/states/
tools/bench/reports/
# lock_model / set_total_wall save originals here when mutating Pam/ENV
**/*.bench-backup-*

# Cam audit data (jsonl)
Cam/**/*.jsonl

# Editor / OS
**/*.swp
**/*.swo
**/*~
.DS_Store

# ME
F/home/.ssh/id*
.secret.sh
RD/
ME.md
