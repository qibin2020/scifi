#!/usr/bin/env python3
"""SciFi — intelligent entry point for the SciF system.

Flow:
  1. Rule-based pre-checks (apptainer, secret, bootstrap)
  2. LLM decides action from user intent + F.usage.md
  3. Direct commands → execute + hookback interpretation
     Interactive commands → hand off to user terminal
     Suggest-only commands → print reason, user runs manually
  4. Concise conclusion from captured output

Stdlib only. No container needed.
"""

import sys, os, json, re, time, subprocess, urllib.request, urllib.error

BASEDIR = os.path.dirname(os.path.abspath(__file__))

# --- Cam ---

_cam_file = None

def _cam_init():
    global _cam_file
    cam_dir = os.path.join(BASEDIR, "Cam")
    try:
        os.makedirs(cam_dir, exist_ok=True)
        _cam_file = os.path.join(cam_dir, f"scifi_{time.strftime('%Y%m%d%H%M%S')}.jsonl")
    except Exception:
        pass

def _cam(event, **data):
    if not _cam_file:
        return
    try:
        record = {"ts": time.strftime('%Y-%m-%dT%H:%M:%S'), "event": event}
        record.update(data)
        with open(_cam_file, "a") as f:
            f.write(json.dumps(record, default=str) + "\n")
    except Exception:
        pass

# --- Rule-based pre-checks ---

def _check_apptainer():
    env_path = os.path.join(BASEDIR, "ENV.sh")
    apptainer = "/cvmfs/atlas.cern.ch/repo/containers/sw/apptainer/x86_64-el10/current/bin/apptainer"
    if os.path.exists(env_path):
        with open(env_path) as f:
            for line in f:
                if line.strip().startswith("export APPTAINER="):
                    apptainer = line.split("=", 1)[1].strip()
    return os.path.isfile(apptainer), apptainer

def _check_secret():
    secret = os.path.join(BASEDIR, "Pam", "gateway.model.yaml")
    if not os.path.isfile(secret):
        return False, "not found"
    with open(secret) as f:
        if "<SETME>" in f.read():
            return False, "has <SETME> placeholders"
    for var in ("ANTHROPIC_API_KEY", "BEDROCK_API_KEY"):
        val = os.environ.get(var, "")
        if not val or val == "<SETME>":
            return False, f"env {var} is unset or '<SETME>'"
    return True, "ok"

def _is_bootstrapped():
    """Check if all three key artifacts exist."""
    return (os.path.isfile(os.path.join(BASEDIR, "Kam", "rl9_micromamba_0.sif"))
            and os.path.isfile(os.path.join(BASEDIR, "Pam", "gateway.sif"))
            and os.path.isfile(os.path.join(BASEDIR, "F", "F.overlay.img")))

def _pre_check():
    """Rule-based checks before LLM. Returns error string or None."""
    ok, path = _check_apptainer()
    if not ok:
        return (
            f"Apptainer not found at {path}\n\n"
            "  Fix: check ENV.sh APPTAINER path, or: module load apptainer\n"
            "  Then: SciF BOOTSTRAP"
        )
    ok, reason = _check_secret()
    if not ok:
        return (
            f"Pam/gateway.model.yaml {reason}\n\n"
            "  Fix: cp Pam/gateway.model.yaml.template Pam/gateway.model.yaml\n"
            "       Edit and fill in your LLM API keys\n"
            "  Then: SciF BOOTSTRAP"
        )
    return None

# --- Gateway + LLM ---

