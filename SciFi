    ts = time.strftime('%Y%m%d%H%M%S')
    fb_id = "FB_%s_%s" % (str(uuid.uuid4())[:8], ts)
    fb_dir = os.path.join(cam_dir, fb_id)
    os.makedirs(fb_dir, exist_ok=True)

    # Write feedback text
    with open(os.path.join(fb_dir, "feedback.txt"), "w") as f:
        f.write("User query: %s\n" % user_msg)
        f.write("Comment: %s\n" % comment)
        f.write("Time: %s\n" % time.strftime('%Y-%m-%d %H:%M:%S'))
        if _session_task:
            f.write("Task: %s\n" % _session_task)
        if _cam_file:
            f.write("Cam log: %s\n" % _cam_file)

    # Identify available artifacts
    artifacts = {}
    artifacts["1"] = ("Feedback text", [os.path.join(fb_dir, "feedback.txt")])
    if _cam_file and os.path.exists(_cam_file):
        artifacts["2"] = ("SciFi session log", [_cam_file])
    run_dir = os.path.join(BASEDIR, "F", "run")
    if os.path.isdir(run_dir):
        run_files = [os.path.join(run_dir, f) for f in os.listdir(run_dir) if f.endswith(".md")]
        if run_files:
            artifacts["3"] = ("Global run/ state", run_files)
    if _session_task:
        task_dir = os.path.join(BASEDIR, "F", "tasks", _session_task)
        if os.path.isdir(task_dir):
            # 4: dot files (.history.md, .memory.md, .suggestion.md, .history_index.md)
            dot_files = [os.path.join(task_dir, f) for f in os.listdir(task_dir) if f.startswith(".")]
            if dot_files:
                artifacts["4"] = ("Task dot files (.history, .memory, .suggestion)", dot_files)
            # 5: task-related Cam jsonl (match task name in filename)
            task_base = _session_task.rsplit("_", 1)[0] if "_" in _session_task else _session_task
            cam_jsonls = glob.glob(os.path.join(cam_dir, "*%s*.jsonl" % task_base))
            if cam_jsonls:
                artifacts["5"] = ("Task-related Cam logs", cam_jsonls)
            # 6: task definition (non-dot .md files)
            def_files = [os.path.join(task_dir, f) for f in os.listdir(task_dir)
                         if f.endswith(".md") and not f.startswith(".")]
            if def_files:
                artifacts["6"] = ("Task definition (.md files)", def_files)

    # Show choices
    print("\n  --- Feedback artifacts ---")
    for k in sorted(artifacts):
        label, files = artifacts[k]
        print("  [%s] %s (%d file%s)" % (k, label, len(files), "s" if len(files) != 1 else ""))
    print("")
    print("  Default: 1,2,3,4  (5 and 6 highly encouraged)")
    selection = input("  Include [1,2,3,4]: ").strip()
    if not selection:
        selection = "1,2,3,4"

    # Collect selected files
    selected_keys = [s.strip() for s in selection.split(",")]
    collected = []
    for k in selected_keys:
        if k in artifacts:
            collected.extend(artifacts[k][1])

    if not collected:
        print("  No artifacts selected. Skipping.")
        return

    # Create tarball
    tgz_path = os.path.join(cam_dir, fb_id + ".tgz")
    with tarfile.open(tgz_path, "w:gz") as tar:
        for fpath in collected:
            if os.path.exists(fpath):
                arcname = os.path.join(fb_id, os.path.relpath(fpath, BASEDIR))
                tar.add(fpath, arcname=arcname)

    # Summary
    print("\n  --- Feedback collected ---")
    print("  File: %s" % tgz_path)
    print("  Contents:")
    for k in selected_keys:
        if k in artifacts:
            print("    [%s] %s" % (k, artifacts[k][0]))
    print("  Size: %s" % _human_size(os.path.getsize(tgz_path)))
    print("")
    print("  Submit this file for feedback. Thank you!")

    # Cleanup temp dir
    import shutil
    shutil.rmtree(fb_dir, ignore_errors=True)


def _human_size(nbytes):
    for unit in ["B", "KB", "MB"]:
        if nbytes < 1024:
            return "%.1f %s" % (nbytes, unit)
        nbytes /= 1024.0
    return "%.1f GB" % nbytes


# --- Entry point ---

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("SciFi — intelligent guide for the SciF system")
        print("")
        print("Usage:")
        print("  SciFi <query>        Interactive mode (waits for feedback)")
        print("  SciFi -- <query>     Batch mode (process and exit)")
        print("")
        print("Examples:")
        print("  SciFi run test_hello")
        print("  SciFi -- status")
        print("  SciFi I want to train a neural network on GPU")
        sys.exit(0)

    _cam_init()

    # Parse mode: "--" = batch, otherwise interactive
    args = sys.argv[1:]
    batch_mode = False
    if args[0] == "--":
        batch_mode = True
        args = args[1:]
    if not args:
        print("No query provided.")
        sys.exit(1)

    user_msg = " ".join(args)
    _cam("query", user=user_msg, mode="batch" if batch_mode else "interactive")
    result = respond(user_msg)
    if result:
        print(result)

    # Batch mode: exit immediately
    if batch_mode:
        sys.exit(0)

    # Interactive mode: feedback only for substantive sessions (run, make, ask)
    if not _session_substantive:
        sys.exit(0)

    print("")
    print("  [Press Enter to exit, or type a comment to leave feedback]")
    try:
        comment = input("  > ").strip()
    except (EOFError, KeyboardInterrupt):
        comment = ""

    if not comment:
        sys.exit(0)

    # User left a comment — collect feedback
    _cam("feedback", comment=comment)
    print("")
    print("  Thank you for the feedback!")
    _collect_feedback(user_msg, comment)
