# --- Route 2 helpers: fence + classify ---

KNOWN_CMDS = {
    "BOOTSTRAP", "START", "END", "STATUS", "RESET", "MAINTAIN",
    "RUN", "MAKE", "ASK", "EVOLVE", "JOBS", "help",
}
DIRECT_CMDS = {"BOOTSTRAP", "START", "END", "STATUS", "RUN", "JOBS", "help"}
INTERACTIVE_CMDS = {"MAKE", "ASK"}
SUGGEST_CMDS = {"RESET", "MAINTAIN"}
# EVOLVE: suggest=direct, model=suggest, code=forbidden


# Restrictiveness order: higher = more restrictive. Fence enforces a floor per
# command type; the LLM can raise it but never lower it.
_RESTRICTIVENESS = {"run": 0, "interactive": 1, "suggest": 2}


def _fence_command(raw_command, llm_action):
    """Validate, fix, and classify a command from LLM output.
    Returns (action, command) where action is 'run', 'interactive', 'suggest', or None.
    Takes the MORE restrictive of fence rule vs LLM intent."""
    cmd = raw_command.strip()
    if not cmd:
        return None, ""

    # Fix: add SciF prefix if missing
    if not cmd.startswith("SciF "):
        cmd = "SciF " + cmd

    # Safety: reject shell metacharacters
    for bad in [";", "|", "&", "`", "$("]:
        if bad in cmd:
            return None, ""

    # Parse: "SciF CMD [args...]"
    parts = cmd.split()
    if len(parts) < 2:
        return None, ""
    scif_cmd = parts[1]

    # Fix: bare task name → "SciF RUN <name>"
    if scif_cmd not in KNOWN_CMDS:
        cmd = "SciF RUN " + " ".join(parts[1:])
        scif_cmd = "RUN"

    # Classify: fence sets the minimum restrictiveness per command type
    if scif_cmd in DIRECT_CMDS:
        fence_action = "run"
    elif scif_cmd in INTERACTIVE_CMDS:
        fence_action = "interactive"
    elif scif_cmd in SUGGEST_CMDS:
        fence_action = "suggest"
    elif scif_cmd == "EVOLVE":
        mode = parts[2] if len(parts) > 2 else "suggest"
        if mode == "suggest":
            fence_action = "run"
        else:  # model, code, unknown
            fence_action = "suggest"
    else:
        fence_action = "suggest"

    # Take the more restrictive of fence rule vs LLM intent.
    # Fence is the floor (e.g. RESET is always at least suggest).
    # LLM can raise it (e.g. flag injection as suggest) but never lower it.
    llm_level = _RESTRICTIVENESS.get(llm_action, 0)
    fence_level = _RESTRICTIVENESS.get(fence_action, 0)
    if llm_level > fence_level:
        return llm_action, cmd
    return fence_action, cmd


# --- Main flow: 3 routes ---

def respond(user_msg):
    # ================================================================
    # ROUTE 1: Early stop (rule-based, no LLM)
    # ================================================================

    msg_lower = user_msg.lower().strip()
    is_play = msg_lower in ("play", "plays", "let's play", "lets play")

    # 1a. Pre-checks: apptainer, secret
    err = _pre_check()
    if err:
        _cam("route1_precheck", error=err[:200])
        if is_play:
            return (
                "Welcome! Almost there — one thing to set up first:\n\n" + err +
                "\n\nOnce fixed, run: SciFi play"
            )
        return err

    # 1b. Auto-bootstrap if not bootstrapped
    if not _is_bootstrapped():
        _cam("route1_bootstrap", user=user_msg)
        print("  [SciFi] System not bootstrapped. Running SciF BOOTSTRAP...\n")
        code, output = _run_scif("SciF BOOTSTRAP")
        if code != 0:
            return "Bootstrap failed:\n" + output[-500:]
        print("")

    # 1c. "play" magic word → welcome + help
    if is_play:
        return _welcome()

    # 1d. Keyword shortcuts (work even without gateway)
    if msg_lower in ("help", "?", "h", "scif help"):
        return _help()
    if msg_lower.startswith("help "):
        return _help(user_msg[5:].strip())

    SHORTCUTS = {
        "start": "SciF START", "stop": "SciF END", "end": "SciF END",
        "status": "SciF STATUS", "jobs": "SciF JOBS",
    }
    for keyword, cmd in SHORTCUTS.items():
        if msg_lower == keyword or msg_lower == "scif " + keyword:
            print("  [SciFi] " + cmd + " ...")
            code, output = _run_scif(cmd)
            return "" if code == 0 else "Command failed (exit %d)." % code

    # ================================================================
    # ROUTE 2 & 3: LLM decides (command or text answer)
    # ================================================================

    reply = _llm_call([
        {"role": "system", "content": DECIDE_PROMPT},
        {"role": "user", "content": user_msg},
    ])

    if not reply:
        _cam("llm_unavailable", user=user_msg)
        return (
            "Gateway not reachable. Start it first:\n"
            "  SciF START\n\n"
            "Then retry: SciFi " + user_msg
        )

    # Parse LLM JSON
    json_match = re.search(r'\{.*\}', reply, re.DOTALL)
    if not json_match:
        return reply  # Route 3: plain text

    try:
        decision = json.loads(json_match.group())
    except json.JSONDecodeError:
        return reply  # Route 3: plain text

    _cam("llm_decision", raw=decision)

    # ================================================================
    # ROUTE 3: Text answer (no command)
    # ================================================================

    if decision.get("action") == "answer" or "command" not in decision:
        return decision.get("text", reply)

    # ================================================================
    # ROUTE 2: SciF command (fence → classify → execute or suggest)
    # ================================================================

    raw_cmd = decision.get("command", "")
    raw_action = decision.get("action", "run")
    action, command = _fence_command(raw_cmd, raw_action)

    if not action:
        # Fence rejected the command — treat as text answer
        return decision.get("text", reply)

    _cam("fenced", action=action, command=command)

    # 2a. Suggest only
    if action == "suggest":
        reason = decision.get("reason", "This command modifies system state. Run it yourself to confirm.")
        return (
            "Suggested command (run it yourself):\n"
            "  " + command + "\n\n"
            "  Why manual: " + reason
        )

    global _session_substantive, _session_task

    # 2b. Interactive handoff
    if action == "interactive":
        _session_substantive = True
        _exec_interactive(command, user_msg)
        return ""

    # 2c. Direct run + hookback
    _session_substantive = True
    print("  [SciFi] " + command + " ...")
    code, output = _run_scif(command)
    _cam("run_result", command=command, exit_code=code, output=output[:500])
    # Track task name for feedback
    task = _extract_task_from_output(output)
    if task:
        _session_task = task

    # Rule-based hookback: detect known patterns before calling LLM
    submitted = re.search(r'\[submitted\] (\S+) . job (\S+) . log: (\S+)', output)
    if submitted:
        task_name, job_id, log_path = submitted.groups()
        return (
            "Submitted %s to SLURM (job %s).\n"
            "  Check:  squeue -j %s  |  tail -f %s\n"
            "  Cancel: scancel %s\n"
            "  Jobs:   SciF JOBS" % (task_name, job_id, job_id, log_path, job_id)
        )

    # Hookback: LLM interprets the output
    interpretation = _llm_call([
        {"role": "system", "content": INTERPRET_PROMPT},
        {"role": "user", "content":
            "Command: " + command + "\nExit code: %d\n\nOutput (tail):\n" % code + output},
    ])

    if interpretation:
        return interpretation
    return "Done." if code == 0 else "Failed (exit %d). Check output above." % code


# --- Session tracking (for feedback) ---

_session_task = None      # set during run if a task was executed
_session_substantive = False  # True if run/interactive happened (feedback-worthy)

def _extract_task_from_output(output):
    """Extract task dir name from driver output like '[run] test_hello → .../test_hello_20260404...'"""
    m = re.search(r'\[run\] \S+ . .*/(\S+_\d{14})', output)
    return m.group(1) if m else None

