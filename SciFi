def _response_meta_raw(data):
    """Extract audit metadata from a raw JSON response dict."""
    meta = {}
    meta["response_id"] = data.get("id")
    meta["response_model"] = data.get("model")
    meta["system_fingerprint"] = data.get("system_fingerprint")
    meta["created"] = data.get("created")
    usage = data.get("usage") or {}
    if usage:
        meta["prompt_tokens"] = usage.get("prompt_tokens")
        meta["completion_tokens"] = usage.get("completion_tokens")
        meta["total_tokens"] = usage.get("total_tokens")
    choices = data.get("choices") or []
    if choices:
        meta["finish_reason"] = choices[0].get("finish_reason")
    return meta


def _llm_call(messages):
    """Single model call via gateway. Returns reply or None. Retries once on timeout."""
    payload = json.dumps({
        "model": MODEL, "messages": messages, "max_tokens": 1024,
    }).encode()
    for attempt in range(2):
        try:
            req = urllib.request.Request(
                GATEWAY_URL + "/v1/chat/completions",
                data=payload,
                headers={"Content-Type": "application/json"},
            )
            with urllib.request.urlopen(req, timeout=30) as resp:
                data = json.loads(resp.read())
                reply = data["choices"][0]["message"]["content"]
                _cam("llm", model=MODEL, reply=reply[:500],
                     attempt=attempt, **_response_meta_raw(data))
                return reply
        except Exception:
            if attempt == 0:
                _cam("llm_retry", model=MODEL, reason="timeout_or_error")
                continue
            return None

# --- Execute SciF command ---

def _run_scif(command):
    """Execute a SciF command. Streams output to terminal, captures tail for hookback.
    Returns (exit_code, tail_output)."""
    if not command.startswith("SciF "):
        return 1, "Invalid command"
    for bad in [";", "|", "&", "`", "$("]:
        if bad in command:
            return 1, f"Unsafe character in command: {bad}"

    scif_path = os.path.join(BASEDIR, "SciF")
    parts = command.split(None, 1)
    cmd = f"{scif_path} {parts[1]}" if len(parts) > 1 else scif_path

    try:
        proc = subprocess.Popen(
            cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
            universal_newlines=True, cwd=BASEDIR,
        )
        lines = []
        for line in proc.stdout:
            sys.stdout.write(line)
            sys.stdout.flush()
            lines.append(line)
        proc.wait()
        # Keep tail for hookback interpretation
        output = "".join(lines[-50:]).strip()
        return proc.returncode, output
    except Exception as e:
        return 1, str(e)

def _exec_interactive(command, user_msg=""):
    """Hand off to user terminal (MAKE, ASK). Returns exit code.
    For MAKE without a file: passes user's text via --desc so maker gets it as initial input."""
    scif_path = os.path.join(BASEDIR, "SciF")
    parts = command.split(None, 1)
    cmd_args = parts[1] if len(parts) > 1 else ""

    # For MAKE without a file arg: pass user's intent via --desc
    if "MAKE" in cmd_args and user_msg and not any(cmd_args.endswith(ext) for ext in [".md", ".txt"]):
        # Escape quotes in user message for shell
        safe_msg = user_msg.replace("'", "'\\''")
        if "--skill" in cmd_args:
            # "MAKE --skill name" → "MAKE --desc '...' --skill name"
            cmd_args = cmd_args.replace("MAKE", "MAKE --desc '%s'" % safe_msg, 1)
        else:
            cmd_args = cmd_args.replace("MAKE", "MAKE --desc '%s'" % safe_msg, 1)

    cmd = "%s %s" % (scif_path, cmd_args)
    print("  [SciFi] handing off to: SciF MAKE ...")
    print("  " + "=" * 50)
    try:
        r = subprocess.run(cmd, shell=True, universal_newlines=True, cwd=BASEDIR)
        return r.returncode
    except Exception as e:
        print("  [SciFi] error: %s" % e)
        return 1

